# Register genome database 
# snpEff will look for a database "species"; the name after colon is descriptive
species.genome : proper_name


# Define path for the reference sequences
# This tells SnpEff where all genome databases are stored
data.dir = data/annotation/snpEff/data


# Important! 
# The most important part is that the genome ID (species) must match the directory name under data.dir and the name used in your SnpEff commands
